{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-scheduler"
  ],
  "model": "openai/gpt-5.5",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://127.0.0.1:9823"
      ]
    },
    "notion": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.notion.com/mcp",
      "oauth": {}
    },
    "linear": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.linear.app/mcp",
      "oauth": {}
    }
  }
}


